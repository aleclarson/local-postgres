{
  "name": "local-postgres",
  "version": "0.1.4",
  "description": "Start and manage a local PostgreSQL server from Node.js using installed Postgres binaries.",
  "license": "MIT OR Apache-2.0",
  "author": "Alec Larson",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleclarson/local-postgres.git"
  },
  "files": [
    "dist",
    "docs",
    "examples"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core.d.mts",
      "import": "./dist/core.mjs",
      "default": "./dist/core.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --sourcemap --watch",
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit",
    "test": "vitest",
    "prepublishOnly": "pnpm build",
    "sync-agent-rules": "curl -fsSL https://gist.githubusercontent.com/aleclarson/4c80686b1c3e204a01cdbe82f8e2c084/raw/AGENTS.md -o AGENTS.md && git add AGENTS.md && git commit -m 'chore: sync agent rules'"
  },
  "dependencies": {
    "modern-tar": "^0.7.6",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "lildocs": "^0.1.16",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "radashi": "^12.9.1",
    "tsdown": "^0.22.3",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.5.1"
}
